# Copy this file to .env and fill in your own values. Never commit real secrets.

# Groq API key — https://console.groq.com/keys
GROQ_API_KEY=gsk_your_groq_api_key_here

# Telegram bot token — from @BotFather
TELEGRAM_TOKEN=your_telegram_bot_token_here

# Google Calendar OAuth (Desktop client) is configured via credentials.json in the
# project root, not here. Create an OAuth "Desktop app" client in Google Cloud Console
# (APIs & Services > Credentials), download it as credentials.json, and place it next
# to this file. The consent screen is in "Testing" mode, so your Google account must
# be listed as a test user. token.json is created automatically after /connect.
